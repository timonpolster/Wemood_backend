:443 {
    tls internal

    reverse_proxy backend:8000

    header {
               X-XSS-Protection "1; mode=block"
               X-Content-Type-Options "nosniff"
               X-Frame-Options "DENY"
               Strict-Transport-Security "max-age=31536000"
               -Server
           }

    log {
            output stdout
            format console
        }
}

:80 {
    redir https://{host}{uri} permanent
}